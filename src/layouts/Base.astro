---
// Phase 3 D-18 Base layout. Every page extends this.
// Imports tokens, fontsource CSS, preloads Bricolage display woff2.
import '../styles/tokens.css';
import '@fontsource-variable/bricolage-grotesque';
import '@fontsource-variable/fraunces';
import '@fontsource-variable/jetbrains-mono';
// Preload only the Bricolage display woff2 actually used above the fold.
// Path is the canonical Fontsource v5 file name for the Latin variable-wght file.
import bricolageDisplay from '@fontsource-variable/bricolage-grotesque/files/bricolage-grotesque-latin-wght-normal.woff2?url';
import StatusPill from '../components/StatusPill.astro';

interface Props {
  title: string;
  bg?: 'paper' | 'ink';
}
const { title, bg = 'paper' } = Astro.props;
const isHome = Astro.url.pathname === '/';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="font" type="font/woff2" href={bricolageDisplay} crossorigin="anonymous" />
  </head>
  <body class={`bg-${bg}`}>
    <a href="#main" class="skip">Skip to content</a>
    <header class="topbar">
      <a href="/" class="brand" aria-current={isHome ? 'page' : undefined}>caleb lim</a>
      <StatusPill />
      <nav aria-label="primary">
        <a href="mailto:caleb.lim.2024@smu.edu.sg" class="nav-link">caleb.lim.2024@smu.edu.sg</a>
        <a href="https://linkedin.com/in/caleblkr" target="_blank" rel="noopener noreferrer" class="nav-link">linkedin</a>
        <a href="/caleb-lim-resume.pdf" download class="nav-link">resume</a>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="foot">
      <span class="left">caleb lim — 2026</span>
      <span class="center">available for part-time, full-time internship roles<br />brand &nbsp;·&nbsp; analyst &nbsp;·&nbsp; design</span>
      <span class="right">singapore · global</span>
    </footer>
  </body>
</html>

<style is:global>
  /* Body background switches per page via bg='paper' | 'ink' prop.
     is:global is required so the body class selector wins (scoped styles hash). */
  body.bg-paper { background: var(--paper); color: var(--ink); }
  body.bg-ink   { background: var(--ink);   color: var(--paper); }
</style>

<style>
  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--sp-5) var(--sp-6);
    font-family: var(--mono);
    font-size: var(--fs-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .topbar .brand {
    font-family: var(--mono);
    font-size: var(--fs-mono);
    letter-spacing: 0.1em;
    text-transform: lowercase;
  }
  .topbar nav {
    display: flex;
    gap: 18px;
    min-width: 1px; /* reserves the grid slot for Phase 4 */
  }
  .topbar nav a:hover { color: var(--terracotta); }

  /* Phase 4 — header chrome links. Inherit .topbar typography; override text-transform to lowercase to match .brand. */
  .topbar nav .nav-link {
    font-family: var(--mono);
    font-size: var(--fs-mono);
    letter-spacing: 0.1em;
    text-transform: lowercase;
    font-weight: 600;
    color: inherit;
    text-decoration: none;
    padding: 4px 0;
  }
  .topbar nav .nav-link:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }
  /* aria-current="page" dim — only ever set on the brand link on splash (Pitfall P-4). */
  .topbar .brand[aria-current="page"] {
    opacity: 0.6;
    pointer-events: none;
  }
  /* Skip-to-content — visually hidden until focused (O-2). */
  .skip {
    position: absolute;
    top: 0;
    left: 0;
    padding: var(--sp-2) var(--sp-4);
    background: var(--ink);
    color: var(--paper);
    font-family: var(--mono);
    font-size: var(--fs-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
    transform: translateY(-200%);
    transition: transform 0.15s ease-out;
    z-index: 100;
  }
  .skip:focus-visible {
    transform: translateY(0);
    outline: 2px solid var(--paper);
    outline-offset: 2px;
  }
  @media (prefers-reduced-motion: reduce) {
    .skip { transition: none; }
  }

  .foot {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    padding: var(--sp-5) var(--sp-6);
    font-family: var(--mono);
    font-size: var(--fs-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
    gap: var(--sp-4);
  }
  .foot .center {
    text-align: center;
    font-family: var(--serif);
    font-style: italic;
    font-size: 14px;
    text-transform: none;
    letter-spacing: 0;
    font-weight: 400;
  }
  .foot .right { text-align: right; }

  @media (max-width: 900px) {
    .foot { grid-template-columns: 1fr; gap: var(--sp-2); text-align: left; }
    .foot .center, .foot .right { text-align: left; }
  }
</style>
