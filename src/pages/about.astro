---
// Phase 3 re-skin — about page on Base, paper canvas, Phase 3 typography.
// Bio paragraph copy is Phase 2 D-12/D-14 contract — preserved verbatim.
// Phase 4 will add the larger contact block per CONTACT-05.
import Base from '../layouts/Base.astro';
---
<Base title="About — Caleb Lim" bg="paper">
  <article class="about">
    <a href="/" class="b-cat-back">← splash</a>
    <h1>Caleb Lim</h1>
    <p>
      I'm Caleb Lim. I work across four lanes — financial models, brand and
      marketing, graphic design, and personal builds — because the same job
      description rarely covers all of them and I'd rather hold the pitch
      deck, the brand mark, and the model behind it without handing any of
      them off. The portfolio is split four ways for the same reason: pick
      the lane you're hiring for and the work that's relevant to it is one
      click away. I built and write this site myself, so the format is its
      own evidence — opinionated layout, deliberate typography, no template
      smell. If you want the long version, the resume's a click below.
    </p>
    <p class="resume-link">
      <a href="/caleb-lim-resume.pdf" download>Download resume (PDF) →</a>
    </p>
    {/* CONTACT-05 — slightly larger contact surface for recruiters who already read the bio.
        Calendly intentionally skipped (researcher + user lock; CONTACT-05 text reads "optional Calendly").
        External LinkedIn anchor establishes the Phase 4 SECOND target=_blank in codebase (first: header in Base.astro). */}
    <section class="contact" aria-labelledby="contact-h">
      <h2 id="contact-h">Get in touch</h2>
      <ul class="contact-list">
        <li>
          <span class="label">email</span>
          <a href="mailto:caleblimster@gmail.com">caleblimster@gmail.com</a>
        </li>
        <li>
          <span class="label">linkedin</span>
          <a href="https://linkedin.com/in/caleblkr" target="_blank" rel="noopener noreferrer">linkedin.com/in/caleblkr</a>
        </li>
      </ul>
    </section>
  </article>
</Base>

<style>
  .about {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--sp-10) var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .b-cat-back {
    display: inline-block;
    background: var(--paper);
    color: var(--ink);
    padding: 8px 14px;
    border-radius: 999px;
    font-family: var(--mono);
    font-size: var(--fs-mono);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    align-self: flex-start;
    border: 1px solid var(--ink);
    transition: background 0.2s ease, color 0.2s ease;
    text-decoration: none;
  }
  .b-cat-back:hover {
    background: var(--terracotta);
    color: var(--paper);
  }
  .b-cat-back:focus-visible {
    outline: 3px solid var(--ink);
    outline-offset: 3px;
  }
  .about h1 {
    font-family: var(--sans);
    font-weight: 800;
    font-size: var(--fs-cat);
    line-height: var(--lh-cat);
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: var(--ink);
    margin: 0;
  }
  .about p {
    font-family: var(--serif);
    font-size: var(--fs-body);
    line-height: var(--lh-bio);
    color: var(--ink);
    margin: 0;
  }
  .about p a {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }
  .about p a:hover {
    color: var(--terracotta);
  }
  .about p a:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 2px;
  }
  .resume-link a {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
  }
  /* Phase 4 — CONTACT-05 contact block. Mirrors CRO label typography from
     [category]/[slug].astro:164–172 (mono uppercase, 0.16em tracking, opacity 0.6).
     External-link safety convention: see Plan 04-01 / Pattern S1. No new tokens. */
  .contact {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    margin-top: var(--sp-5);
  }
  .contact h2 {
    font-family: var(--mono);
    font-size: var(--fs-mono);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--ink);
    opacity: 0.6;
    margin: 0;
  }
  .contact-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .contact-list li {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: var(--sp-4);
    align-items: baseline;
  }
  .contact-list .label {
    font-family: var(--mono);
    font-size: var(--fs-mono);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--ink);
    opacity: 0.6;
  }
  .contact-list a {
    font-family: var(--serif);
    font-size: var(--fs-body);
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }
  .contact-list a:hover { color: var(--terracotta); }
  .contact-list a:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 2px;
  }

  @media (max-width: 900px) {
    .about { padding: var(--sp-8) var(--sp-5); }
  }
  @media (max-width: 600px) {
    .contact-list li { grid-template-columns: 1fr; gap: var(--sp-1); }
  }
</style>
