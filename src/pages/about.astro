---
// Phase 3 re-skin — about page on Base, paper canvas, Phase 3 typography.
// Bio paragraph copy revised 2026-05-18 (UAT-driven) for a more humanised tone —
// supersedes the Phase 2 D-12/D-14 verbatim contract. Word count stays in the
// 80-150 band; banned words (passionate/multidisciplinary/intersection of) avoided.
// Phase 4 added the contact block per CONTACT-05 + 3 photo wireframes.
import Base from '../layouts/Base.astro';
---
<Base title="About — Caleb Lim" bg="paper">
  <article class="about">
    <a href="/" class="b-cat-back">← Splash</a>
    <h1>Caleb Lim</h1>
    <p class="bio">
      I'm Caleb, and I don't pick a lane. I sit between financial models,
      brand strategy, graphic design, and the side projects that don't fit
      anywhere, because the work that excites me rarely fits a job spec's
      bullet points. Numbers in the morning, type at night, a campaign
      brief in between. I'd rather hold the pitch deck, the brand mark, and
      the model behind it than hand any of them off, and this site is part
      of that argument. I built it, I wrote it, I picked every type pairing
      and rotated card. Pick the room that fits your role; the work in it
      is the case. If you want the full story, the resume's one click below.
    </p>

    {/* Values pills — six attribute chips sourced from the bio's voice (owner mentality,
        cross-functional, etc.). Each pill subtly rotated for editorial rhythm matching the
        splash card tilt language; mono uppercase to read as taxonomy markers, not labels. */}
    <section class="values" aria-labelledby="values-h">
      <h2 id="values-h" class="values-h">Values</h2>
      <ul class="values-list">
        <li class="values-pill">Curious</li>
        <li class="values-pill">Challenges Processes</li>
        <li class="values-pill">AI Agency &amp; Stewardship</li>
        <li class="values-pill">Leverages on AI</li>
        <li class="values-pill">Thrives in Ambiguity</li>
        <li class="values-pill">Adaptive</li>
      </ul>
    </section>

    {/* Photo wireframes — placeholders for personality photos. Replace with real images
        from src/assets/about/ when available. Wireframes are intentional scaffolding
        (dashed border + caption hint) so the layout reads as "photos coming" rather
        than as a polished gallery missing assets. */}
    <section class="about-photos-track" aria-label="Photos of Caleb">
      <figure class="about-photo">
        <span class="about-photo-tag">PHOTO · 01</span>
        <span class="about-photo-hint">at the desk</span>
      </figure>
      <figure class="about-photo">
        <span class="about-photo-tag">PHOTO · 02</span>
        <span class="about-photo-hint">in the studio</span>
      </figure>
      <figure class="about-photo">
        <span class="about-photo-tag">PHOTO · 03</span>
        <span class="about-photo-hint">process / sketch</span>
      </figure>
    </section>

    <p class="resume-link">
      <a href="/caleb-lim-resume.pdf" download>Download resume (PDF) →</a>
    </p>
    {/* CONTACT-05 — slightly larger contact surface for recruiters who already read the bio.
        Calendly intentionally skipped (researcher + user lock; CONTACT-05 text reads "optional Calendly").
        External LinkedIn anchor establishes the Phase 4 SECOND target=_blank in codebase (first: header in Base.astro). */}
    <section id="contact" class="contact" aria-labelledby="contact-h">
      <h2 id="contact-h">Get in touch</h2>
      <ul class="contact-list">
        <li>
          <span class="label">email</span>
          <a href="mailto:caleb.lim.2024@smu.edu.sg">caleb.lim.2024@smu.edu.sg</a>
        </li>
        <li>
          <span class="label">linkedin</span>
          <a href="https://linkedin.com/in/caleblkr" target="_blank" rel="noopener noreferrer">linkedin.com/in/caleblkr</a>
        </li>
      </ul>
    </section>
  </article>
</Base>

<style>
  .about {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--sp-10) var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  /* Photo wireframes — horizontally scrollable carousel of placeholder figures.
     Centered when the row fits the viewport; scroll-snaps + scrollbar styling when
     it overflows. Initial scroll position is centered via the inline script at the
     end of this file. Each wireframe stays uniform (no --wide variant) so the
     carousel has a consistent rhythm. */
  .about-photos-track {
    display: flex;
    gap: var(--sp-3);
    margin: var(--sp-2) 0;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    justify-content: center;       /* centers when content fits without scroll */
    padding: 0 var(--sp-2) var(--sp-3);
    scrollbar-width: thin;
    scrollbar-color: var(--terracotta) transparent;
  }
  .about-photos-track::-webkit-scrollbar { height: 6px; }
  .about-photos-track::-webkit-scrollbar-thumb {
    background: var(--terracotta);
    border-radius: 999px;
  }
  .about-photo {
    flex: 0 0 32%;
    min-width: 200px;
    aspect-ratio: 4 / 5;
    margin: 0;
    border: 1.5px dashed var(--terracotta);
    border-radius: 6px;
    background: color-mix(in oklab, var(--paper) 92%, var(--terracotta) 8%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    padding: var(--sp-3);
    color: var(--ink);
    text-align: center;
    scroll-snap-align: center;
  }
  .about-photo-tag {
    font-family: var(--mono);
    font-size: var(--fs-mono);
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--terracotta);
    text-transform: uppercase;
  }
  .about-photo-hint {
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.92rem;
    line-height: 1.35;
    color: color-mix(in oklab, var(--ink) 70%, transparent);
    max-width: 18ch;
  }
  @media (max-width: 600px) {
    .about-photo {
      flex: 0 0 70%;
      aspect-ratio: 4 / 5;
    }
    .about-photos-track {
      justify-content: flex-start;  /* swipeable from leftmost on narrow screens */
    }
  }
  .b-cat-back {
    display: inline-block;
    background: var(--paper);
    color: var(--ink);
    padding: 8px 14px;
    border-radius: 999px;
    font-family: var(--mono);
    font-size: var(--fs-mono);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    align-self: flex-start;
    border: 1px solid var(--ink);
    transition: background 0.2s ease, color 0.2s ease;
    text-decoration: none;
  }
  .b-cat-back:hover {
    background: var(--terracotta);
    color: var(--paper);
  }
  .b-cat-back:focus-visible {
    outline: 3px solid var(--ink);
    outline-offset: 3px;
  }
  .about h1 {
    font-family: var(--sans);
    font-weight: 800;
    font-size: var(--fs-cat);
    line-height: var(--lh-cat);
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: var(--ink);
    margin: 0;
  }
  .about p {
    font-family: var(--serif);
    font-size: var(--fs-body);
    line-height: var(--lh-bio);
    color: var(--ink);
    margin: 0;
  }
  .about p a {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }
  .about p a:hover {
    color: var(--terracotta);
  }
  .about p a:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 2px;
  }

  /* Values pills — six attribute chips between the bio paragraph and the photo
     wireframes. Outlined chips alternate with filled chips drawn from the new
     earth-tone palette (acid turmeric, terracotta taupe, umber design). Subtle
     ±1deg rotation per chip echoes the splash discipline-card tilt language. */
  .values {
    margin: var(--sp-4) 0 var(--sp-4); /* 2026-05-18 (UAT): tightened top margin so values sits closer to the bio paragraph above */
  }
  .values-h {
    font-family: var(--mono);
    font-size: var(--fs-mono); /* was 11px; exact match per 05-TOKEN-MAP */
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    opacity: 0.7;
    margin: 0 0 var(--sp-2); /* 2026-05-18 (UAT): tightened bottom margin so heading sits closer to its pills */
  }
  .values-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 12px 12px;
  }
  .values-pill {
    font-family: var(--sans);
    font-size: var(--fs-tile-role); /* was 13px; exact match per 05-TOKEN-MAP */
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--ink);
    padding: 7px 16px;
    border: 1.5px solid var(--ink);
    border-radius: 999px;
    background: transparent;
    white-space: nowrap;
    line-height: 1.2;
    cursor: default; /* 2026-05-18 (UAT): pills are non-interactive labels, not links — kill the I-beam text cursor */
    transition: transform 180ms ease, background-color 180ms ease,
                border-color 180ms ease, color 180ms ease,
                box-shadow 180ms ease;
  }
  .values-pill:hover {
    background: var(--terracotta);
    border-color: var(--terracotta);
    color: var(--paper);
    transform: translateY(-3px);
    box-shadow: 0 6px 14px rgba(15, 13, 12, 0.15);
  }

  .resume-link a {
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--fs-body); /* was 16px; migrated to --fs-body (15.5px) per 05-TOKEN-MAP */
  }
  /* Phase 4 — CONTACT-05 contact block. Mirrors CRO label typography from
     [category]/[slug].astro:164–172 (mono uppercase, 0.16em tracking, opacity 0.6).
     External-link safety convention: see Plan 04-01 / Pattern S1. No new tokens. */
  .contact {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    margin-top: var(--sp-5);
  }
  .contact h2 {
    font-family: var(--mono);
    font-size: var(--fs-mono);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--ink);
    opacity: 0.6;
    margin: 0;
  }
  .contact-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .contact-list li {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: var(--sp-4);
    align-items: baseline;
  }
  .contact-list .label {
    font-family: var(--mono);
    font-size: var(--fs-mono);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--ink);
    opacity: 0.6;
  }
  .contact-list a {
    font-family: var(--serif);
    font-size: var(--fs-body);
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }
  .contact-list a:hover { color: var(--terracotta); }
  .contact-list a:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 2px;
  }

  @media (max-width: 900px) {
    .about { padding: var(--sp-8) var(--sp-5); }
  }
  @media (max-width: 600px) {
    .contact-list li { grid-template-columns: 1fr; gap: var(--sp-1); }
  }
</style>

<script>
  // On load, if the photo carousel overflows the viewport (typically narrower
  // screens), pre-scroll it to the centre so the middle wireframe is the
  // "initial" view. When the row fits without overflow, CSS justify-content: center
  // already centres the track and this script is a no-op.
  const track = document.querySelector<HTMLElement>('.about-photos-track');
  if (track && track.scrollWidth > track.clientWidth) {
    track.scrollLeft = (track.scrollWidth - track.clientWidth) / 2;
  }

  // OPEN-TO-ROLES island hand-off: when arrived via /about?to=contact, force the
  // page to the top first, then auto-scroll DELIBERATELY SLOWLY to the contact
  // section so the user reads the bio on the way down. We can't use
  // scrollIntoView({behavior:'smooth'}) — browsers cap that at ~500ms regardless
  // of distance. RAF + easeInOutQuad over 1800ms gives a readable pace.
  // The query-param flag (not #contact hash) is what lets us animate — hashes
  // cause an instant browser snap. We strip the param after triggering so a
  // refresh doesn't replay the scroll.
  const params = new URLSearchParams(window.location.search);
  if (params.get('to') === 'contact') {
    const target = document.getElementById('contact');
    if (target) {
      window.scrollTo(0, 0);
      history.replaceState({}, '', window.location.pathname);
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced) {
        // Reduced-motion: just jump to the section after a tick.
        window.setTimeout(() => target.scrollIntoView({ block: 'start' }), 150);
      } else {
        const slowScrollTo = (endY: number, duration: number) => {
          const startY = window.scrollY;
          const distance = endY - startY;
          const startTime = performance.now();
          const ease = (t: number) =>
            t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
          const tick = (now: number) => {
            const elapsed = now - startTime;
            const t = Math.min(elapsed / duration, 1);
            window.scrollTo(0, startY + distance * ease(t));
            if (t < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        };
        // Brief settle delay so the page paints at top first.
        window.setTimeout(() => {
          const endY = target.getBoundingClientRect().top + window.scrollY;
          slowScrollTo(endY, 1800);
        }, 350);
      }
    }
  }
</script>
