---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import fs from 'node:fs/promises';
import path from 'node:path';
import { DISCIPLINE_ACCENT } from '../../styles/disciplines';
import type { Category } from '../../content/categories';

type Piece = CollectionEntry<'pieces'>;
interface NeighbourRef {
  slug: string;
  category: Category;
  title: string;
}

export async function getStaticPaths() {
  const all = await getCollection('pieces', ({ data }) => data.draft !== true);

  // Group by category and sort each group by `data.order` ASC.
  // MUST match the gallery's sort key at src/pages/[category].astro:25 verbatim.
  // Pitfall P-1: drift between gallery sort and prev/next sort breaks recruiter UX.
  const byCategory: Record<Category, Piece[]> = {
    design: [], finance: [], personal: [], marketing: [],
  };
  for (const p of all) {
    const cat = p.data.category as Category;
    byCategory[cat].push(p);
  }
  for (const cat of Object.keys(byCategory) as Category[]) {
    byCategory[cat].sort((a, b) => a.data.order - b.data.order);
  }

  const toRef = (p: Piece | null): NeighbourRef | null =>
    p ? { slug: p.id, category: p.data.category as Category, title: p.data.title } : null;

  return all.map((piece) => {
    const sibs = byCategory[piece.data.category as Category];
    const idx = sibs.findIndex((s) => s.id === piece.id);
    return {
      params: { category: piece.data.category, slug: piece.id },
      props: {
        piece,
        prev: toRef(idx > 0 ? sibs[idx - 1] : null),
        next: toRef(idx < sibs.length - 1 ? sibs[idx + 1] : null),
      },
    };
  });
}

interface Props {
  piece: CollectionEntry<'pieces'>;
  prev: NeighbourRef | null;
  next: NeighbourRef | null;
}
const { piece, prev, next } = Astro.props;
const { title, hero, context, role, outcome, category, pdfPaginate, fullPdf } = piece.data;
const slug = piece.id;

// Read .cache.json sidecar at build time for dimensions (avoids CLS — Pitfall 1)
let thumbCache: { pages: Array<{ n: number; w: number; h: number; bytes?: number; file: string }> } | null = null;
try {
  const cachePath = path.join(process.cwd(), 'public', 'generated', 'pdf-thumbs', slug, '.cache.json');
  thumbCache = JSON.parse(await fs.readFile(cachePath, 'utf8'));
} catch { /* no thumbs for this piece — skip pagination */ }

// Preserve pdfPaginate array order (D-09: NO re-sort — Caleb may lead with the punchline).
// Use p.file from the cache (D-05: page 1 → cover.webp, others → page-{N}.webp); never compute the URL from p.n.
const paginatedPages = pdfPaginate && thumbCache
  ? (pdfPaginate
      .map((n) => thumbCache!.pages.find((p) => p.n === n))
      .filter(Boolean) as Array<{ n: number; w: number; h: number; file: string }>)
  : [];

const accent = DISCIPLINE_ACCENT[category as Category];

// UI-SPEC.md "Detail page copy" line 303 — back-pill label per discipline.
// 2026-05-18 (UAT): Title-cased to match the rest of the site's chrome — was lowercase.
const backLabel: Record<Category, string> = {
  design:    '← Graphic / Design',
  finance:   '← Financial / Models',
  personal:  '← Personal / Projects',
  marketing: '← Marketing',
};
---
<Base title={`${title} — Caleb Lim`} bg="paper">
  <article class="detail" style={`--accent: ${accent}`}>
    <header class="detail-head">
      <a href={`/${category}`} class="b-cat-back">{backLabel[category as Category]}</a>
      <h1>{title}</h1>
    </header>

    {/* PIECE-01: large hero rendered via Astro's optimized image component, NEVER an iframe-PDF */}
    {/* Phase 5 Plan 05-04: priority + sizes — this is the detail-page LCP element,
        always above the fold. The paginated PDF slides below stay lazy (FOUND-02). */}
    <Image
      src={hero}
      alt={title}
      class="detail-hero"
      priority
      sizes="(max-width: 960px) 100vw, 960px"
    />

    {/* PIECE-02: three blurb blocks — Context / Role / Outcome with uppercase mono labels */}
    <section class="cro">
      <div class="cro-block">
        <span class="label">Context</span>
        <p>{context}</p>
      </div>
      <div class="cro-block">
        <span class="label">Role</span>
        <p>{role}</p>
      </div>
      <div class="cro-block">
        <span class="label">Outcome</span>
        <p>{outcome}</p>
      </div>
    </section>

    {/* PIECE-04: paginated <img> sequence (plain HTML img tag, NOT Astro's optimized image component — Pitfall 1: that component cannot resolve public/ paths). */}
    {/* Width/height sourced from .cache.json for CLS prevention. Render order = pdfPaginate order (D-09). */}
    {paginatedPages.length > 0 && (
      <section class="paginated-pages">
        {paginatedPages.map((p) => (
          <img
            src={`/generated/pdf-thumbs/${slug}/${p.file}`}
            width={p.w}
            height={p.h}
            alt={`${title} — page ${p.n}`}
            loading="lazy"
          />
        ))}
      </section>
    )}

    {/* PIECE-06: optional Open full PDF link — surfaces only on pieces with fullPdf set (D-17). */}
    {fullPdf && (
      <p class="full-pdf-link">
        <a href={fullPdf} download>Open full PDF →</a>
      </p>
    )}

    {/* PIECE-05 prev/next pager — same-discipline only, hide at edges (O-1, Pitfall P-3). */}
    {/* Back-pill (line 52) already satisfies the "Back to Category" half — do NOT duplicate (Pitfall P-2). */}
    {(prev || next) && (
      <nav class="detail-pager" aria-label="other pieces in this discipline">
        {prev ? (
          <a class="pager-link prev" href={`/${prev.category}/${prev.slug}`} rel="prev">
            <span class="pager-dir">← previous</span>
            <span class="pager-title">{prev.title}</span>
          </a>
        ) : <span />}
        {next ? (
          <a class="pager-link next" href={`/${next.category}/${next.slug}`} rel="next">
            <span class="pager-dir">next →</span>
            <span class="pager-title">{next.title}</span>
          </a>
        ) : <span />}
      </nav>
    )}
  </article>
</Base>

<style>
  .detail {
    max-width: 960px;
    margin: 0 auto;
    padding: var(--sp-6);
  }
  .detail-head {
    border-top: 4px solid var(--accent);
    padding-top: var(--sp-4);
    margin-bottom: var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .b-cat-back {
    display: inline-block;
    background: var(--paper);
    color: var(--ink);
    padding: 8px 14px;
    border-radius: 999px;
    font-family: var(--mono);
    font-size: var(--fs-mono);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    align-self: flex-start;
    border: 1px solid var(--ink);
    transition: background 0.2s ease, color 0.2s ease;
  }
  /* D-06 Touch-hover gate (Plan 05-07 Task 1). Back-pill hover color/bg only on
     devices with a real hover mechanism. */
  @media (hover: hover) and (pointer: fine) {
    .b-cat-back:hover {
      background: var(--accent);
      color: var(--paper);
    }
  }
  .b-cat-back:focus-visible {
    outline: 3px solid var(--ink);
    outline-offset: 3px;
  }
  .detail h1 {
    font-family: var(--sans);
    font-weight: 800;
    font-size: var(--fs-cat);
    line-height: var(--lh-cat);
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: var(--ink);
    margin: 0;
  }
  .detail-hero {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin-bottom: var(--sp-8);
  }
  .cro {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
    margin-bottom: var(--sp-8);
  }
  .cro-block {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .cro .label {
    font-family: var(--mono);
    font-size: var(--fs-mono);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
    opacity: 0.6;
  }
  .cro p {
    font-family: var(--serif);
    font-size: var(--fs-body);
    line-height: var(--lh-bio);
    color: var(--ink);
    margin: 0;
  }
  .paginated-pages {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    margin-bottom: var(--sp-8);
  }
  .paginated-pages img {
    width: 100%;
    height: auto;
    border-radius: 6px;
  }
  .full-pdf-link {
    margin: var(--sp-6) 0;
  }
  .full-pdf-link a {
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--fs-body); /* was 16px; migrated to --fs-body (15.5px) per 05-TOKEN-MAP */
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }
  /* D-06 Touch-hover gate (Plan 05-07 Task 1). Color-only hover gated; the
     :focus-visible outline rule stays outside. */
  @media (hover: hover) and (pointer: fine) {
    .full-pdf-link a:hover {
      color: var(--accent);
    }
  }
  .full-pdf-link a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .detail-pager {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-6);
    margin-top: var(--sp-8);
    padding-top: var(--sp-5);
    border-top: 1px solid var(--ink);
  }
  .pager-link {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    color: var(--ink);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .pager-link.next {
    text-align: right;
    align-items: flex-end;
  }
  .pager-dir {
    font-family: var(--mono);
    font-size: var(--fs-mono);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
    opacity: 0.6;
  }
  .pager-title {
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--fs-body); /* was 16px; migrated to --fs-body (15.5px) per 05-TOKEN-MAP */
    line-height: var(--lh-bio);
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }
  /* D-06 Touch-hover gate (Plan 05-07 Task 1). Pager-link descendant color
     change gated; :focus-visible outline stays outside. */
  @media (hover: hover) and (pointer: fine) {
    .pager-link:hover .pager-title { color: var(--accent); }
  }
  .pager-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }
  @media (prefers-reduced-motion: reduce) {
    .pager-link { transition: none; }
  }

  @media (max-width: 900px) {
    .detail { padding: var(--sp-5); }
    .detail-pager { grid-template-columns: 1fr; gap: var(--sp-5); }
    .pager-link.next { text-align: left; align-items: flex-start; }
  }
</style>
