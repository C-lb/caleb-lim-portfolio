---
// Phase 3 DisciplineCard — single source of truth for the four discipline cards
// on splash + 404. CSS verbatim from sketch lines 456-516. Decoration per
// D-03 k1-k4 mapping. Used in <a> form so the entire card is the click target.
import type { Category } from '../content/categories';

interface Props {
  category: Category;
  k: 1 | 2 | 3 | 4;
  index: 1 | 2 | 3 | 4;
}
const { category, k, index } = Astro.props;

// UI-SPEC Copywriting Contract overridden by user during phase-exit walk:
// drop slash separator for parallel reading at recruiter skim-speed.
const cardLabel: Record<Category, string> = {
  design:    'Graphic Design',
  finance:   'Financial Models',
  personal:  'Personal Projects',
  marketing: 'Marketing',
};

// k2 deco contains a Fraunces italic numeral; the rest are CSS-only (empty span).
const k2Numeral = '2';
---
<a href={`/${category}`} class={`b-card k${k}`}>
  <span class="b-card-no">0{index} / 04</span>
  <div>
    <span class="b-card-name">{cardLabel[category]}</span>
  </div>
  <span class="b-card-cue">View the work →</span>
  <span class="deco" aria-hidden="true">{k === 2 ? k2Numeral : ''}</span>
</a>

<style>
  .b-card {
    position: relative;
    border-radius: 10px;
    padding: 22px 22px 24px; /* phase-exit walk: beefed for primary-nav weight */
    cursor: pointer;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 4px;
    min-height: 180px; /* phase-exit walk: cards must read as primary nav, not asides */
    text-decoration: none;
    box-shadow: 0 1px 0 rgba(15, 13, 12, 0.15);
  }
  .b-card:hover {
    transform: translateY(-4px) rotate(-0.3deg);
    box-shadow: 0 10px 22px rgba(15, 13, 12, 0.22);
  }
  .b-card:focus-visible {
    outline: 3px solid var(--ink);
    outline-offset: 4px;
  }
  /* k3 (turmeric) — default ink outline reads clearly; no override needed */

  .b-card-no {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.85;
  }
  .b-card-name {
    font-family: var(--sans);
    font-weight: 800;
    font-size: clamp(28px, 3.4vw, 44px); /* phase-exit walk: bumped from --fs-card */
    line-height: 0.92;
    letter-spacing: -0.035em;
    text-transform: uppercase;
    align-self: end;
  }
  .b-card-cue {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    align-self: end;
    margin-top: var(--sp-2);
    opacity: 0.85;
  }

  /* k1 = Design (terracotta) — outline circle top-right (sketch lines 495-497) */
  .b-card.k1 {
    background: var(--terracotta);
    color: var(--paper);
    transform: rotate(-1deg);
  }
  .b-card.k1 .deco {
    position: absolute;
    right: -22px;
    top: -22px;
    width: 100px;
    height: 100px;
    border: 9px solid var(--paper);
    border-radius: 50%;
  }

  /* k2 = Finance (cobalt) — oversized italic Fraunces numeral in lime (sketch lines 498-503) */
  .b-card.k2 {
    background: var(--cobalt);
    color: var(--paper);
    transform: rotate(1deg);
  }
  .b-card.k2 .deco {
    position: absolute;
    top: 18px;
    right: 16px;
    font-family: var(--serif);
    font-style: italic;
    font-size: 64px;
    font-weight: 300;
    color: var(--acid);
    line-height: 0.8;
  }

  /* k3 = Personal (turmeric, light) — horizontal dotted line */
  .b-card.k3 {
    background: var(--acid);
    color: var(--ink); /* turmeric bg → ink */
    transform: rotate(-0.5deg);
  }
  .b-card.k3 .deco {
    position: absolute;
    left: 16px;
    right: 16px;
    top: 50%;
    height: 24px;
    background-image: repeating-linear-gradient(90deg, var(--ink) 0, var(--ink) 2px, transparent 2px, transparent 10px);
    opacity: 0.55;
  }

  /* k4 = Marketing (olive lime, dark) — accent triangle */
  .b-card.k4 {
    background: var(--plum);
    color: var(--paper); /* olive lime bg → paper */
    transform: rotate(0.7deg);
  }
  .b-card.k4 .deco {
    position: absolute;
    top: 36px;
    right: 18px;
    width: 56px;
    height: 56px;
    background: var(--acid);
    clip-path: polygon(50% 0%, 100% 100%, 0 100%);
  }
</style>
