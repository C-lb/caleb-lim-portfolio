---
// Phase 3 D-05 Bucket B (3-5 pieces) — sketch's exact 5-tile composition.
// CSS verbatim from sketch lines 573-612. Renders only N tiles where N = pieces.length.
// Phase 5 Plan 05-04: tile internals rewritten to match GalleryA12 — hero
// promoted to 60% LEFT grid cell (was opacity-0.55 watermark); .deco dropped;
// .tag inside .meta; p1 carries `priority`. OUTER bucket grid spans p1-p5 are
// preserved (sketch composition).
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { Category } from '../content/categories';

interface Props {
  pieces: CollectionEntry<'pieces'>[];
  category: Category;
}
const { pieces, category } = Astro.props;
const total = pieces.length;
// Sketch composition uses p1..p5 slot CSS classes. Map index → slot.
---
<div class="b-pieces">
  {pieces.map((piece, i) => {
    const slot = i + 1;
    return (
      <a href={`/${category}/${piece.id}`} class={`b-piece p${slot}`}>
        <Image
          src={piece.data.hero}
          alt={piece.data.title}
          class="cover"
          priority={slot === 1}
          widths={[280, 560]}
          sizes="(max-width: 900px) 50vw, 240px"
        />
        <div class="meta">
          <span class="tag">0{slot} / 0{total}</span>
          <span class="ttl">{piece.data.title}</span>
          <span class="role">{piece.data.role}</span>
        </div>
      </a>
    );
  })}
</div>

<style>
  .b-pieces {
    margin-top: var(--sp-6);
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: 240px;
    gap: 12px; /* sketch line 578 — UI-SPEC OVERRIDE-03 */
  }
  /* Plan 05-04: tile is a 60/40 grid — hero in column 1, text column 2.
     Per-bucket outer spans on .p1..p5 (below) place these tiles in the larger
     sketch composition; only INTERNAL layout changed. */
  .b-piece {
    display: grid;
    grid-template-columns: 60% 40%;
    aspect-ratio: 4 / 5;
    border-radius: 8px;
    overflow: hidden;
    position: relative;
    cursor: pointer;
    transition: transform 0.25s ease;
    text-decoration: none;
  }
  /* D-06 Touch-hover gate (Plan 05-07 Task 1). Tile scale+rotate only fires on
     devices with a real hover mechanism — on touch, first tap navigates. */
  @media (hover: hover) and (pointer: fine) {
    .b-piece:hover {
      transform: scale(1.02) rotate(-0.3deg);
      z-index: 2;
    }
  }
  .b-piece:focus-visible {
    outline: 3px solid var(--paper);
    outline-offset: 3px;
  }
  /* Plan 05-04: hero is a grid child at full opacity (was opacity 0.55 watermark — BLOCKER-2). */
  .b-piece .cover {
    grid-column: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 1;
  }
  /* Plan 05-04: meta column carries the per-slot accent background (Q3 preservation). */
  .b-piece .meta {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--sp-4);
    gap: var(--sp-2);
    background: var(--accent-bg, transparent);
  }
  .b-piece .tag {
    font-family: var(--mono);
    font-size: var(--fs-mono);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .b-piece .ttl {
    font-family: var(--sans);
    font-weight: 700;
    font-size: var(--fs-ttl);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .b-piece .role {
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--fs-tile-role);
    line-height: 1.2;
  }

  /* Sketch lines 597-612 verbatim — outer grid spans + per-slot accent
     preserved. Each per-slot color flows into --accent-bg consumed by .meta;
     the rotate transforms ride the outer .b-piece. */
  .b-piece.p1 {
    grid-column: span 3;
    grid-row: span 2;
    --accent-bg: var(--terracotta);
    color: var(--paper);
    transform: rotate(-0.6deg);
  }
  .b-piece.p2 {
    grid-column: span 3;
    --accent-bg: var(--cobalt);
    color: var(--paper);
  }
  .b-piece.p3 {
    grid-column: span 2;
    --accent-bg: var(--acid);
    color: var(--ink);
    transform: rotate(0.5deg);
  }
  .b-piece.p4 {
    grid-column: span 2;
    --accent-bg: var(--plum);
    color: var(--paper);
  }
  .b-piece.p5 {
    grid-column: span 2;
    --accent-bg: var(--teal);
    color: var(--paper);
    transform: rotate(-0.4deg);
  }

  /* Mobile (≤540px): flatten to hero TOP / text BOTTOM 60/40 split */
  @media (max-width: 540px) {
    .b-piece {
      grid-template-columns: 1fr;
      grid-template-rows: 60% 40%;
    }
    .b-piece .cover { grid-column: 1; grid-row: 1; }
    .b-piece .meta  { grid-column: 1; grid-row: 2; }
  }

  /* Mobile collapse @ ≤900px (sketch lines 615-626) */
  @media (max-width: 900px) {
    .b-pieces {
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: auto;
    }
    .b-piece {
      grid-column: span 1 !important;
      grid-row: span 1 !important;
      aspect-ratio: 4/5;
      min-height: 220px;
    }
  }
</style>
