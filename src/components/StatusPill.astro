---
// Phase 3 D-11 status pill — uppercase mono "OPEN TO ROLES" with pulsing lime dot.
// 2026-05-18: lifted to a fixed "dynamic island" pinned top-center, persists through scroll.
// 2026-05-18 (v2): pill is now a link → /about#contact, scrolls to the Get-in-touch block.
---
<div class="pill-island">
  <a class="pill" href="/about?to=contact" aria-label="Open to roles — go to contact section">
    <span class="dot" aria-hidden="true"></span>OPEN TO ROLES
  </a>
</div>

<style>
  /* Apple-style Dynamic Island: fixed top-center, never scrolls, identical
     placement on desktop and mobile. pointer-events:none on the wrapper lets
     clicks pass through the surrounding gutter to anything underneath; the pill
     itself re-enables them. The 100vw width + flex-center guarantees true
     viewport centring at every breakpoint without any per-screen tweaking. */
  .pill-island {
    position: fixed;
    top: 12px;
    left: 0;
    right: 0;
    width: 100vw;
    display: flex;
    justify-content: center;
    pointer-events: none;
    z-index: 90;
  }
  .pill {
    pointer-events: auto;
    background: var(--ink);
    color: var(--paper);
    text-decoration: none;
    padding: 9px 20px;
    border-radius: 999px;
    font-family: var(--mono);
    font-size: var(--fs-mono);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    line-height: 1;
    cursor: pointer;
    box-shadow:
      0 10px 28px rgba(0, 0, 0, 0.28),
      0 2px 6px rgba(0, 0, 0, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    transition: transform 240ms cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 240ms ease;
  }
  /* D-06 Touch-hover gate: hover-scale only fires on devices with a real hover
     mechanism. Touch devices skip the phantom hover state — tap navigates
     immediately to /about?to=contact. Plan 05-07 Task 1. */
  @media (hover: hover) and (pointer: fine) {
    .pill:hover {
      transform: scale(1.04);
      box-shadow:
        0 14px 34px rgba(0, 0, 0, 0.32),
        0 3px 8px rgba(0, 0, 0, 0.2),
        inset 0 1px 0 rgba(255, 255, 255, 0.08);
    }
  }
  .pill:focus-visible {
    outline: 2px solid var(--lime);
    outline-offset: 3px;
  }
  .pill .dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--lime);
    margin-right: 9px;
    box-shadow: 0 0 6px rgba(168, 192, 80, 0.55);
    animation: pulse 1.6s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.4; }
  }
  @media (prefers-reduced-motion: reduce) {
    .pill { transition: none; }
    .pill:hover { transform: none; }
  }
</style>
